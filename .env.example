# ============================================================
# SAM Assistive Vision - Environment Variables Template
# ============================================================
# Copy this file to .env and tune for your machine.
# Do not commit .env because it may later contain private endpoints or keys.
# ============================================================

# Server
APP_NAME="SAM Assistive Vision API"
APP_VERSION="0.1.0"
HOST=0.0.0.0
PORT=8000
DEBUG=true
MODEL_DEVICE=auto
HF_LOCAL_FILES_ONLY=true

# Per-service mock flags
MOCK_STT=false
MOCK_SAM=false
MOCK_BLIP=false
MOCK_OLLAMA=false
MOCK_TTS=false

# Mock timing (ms)
MOCK_STT_DELAY_MS=150
MOCK_SAM_DELAY_MS=120
MOCK_BLIP_DELAY_MS=600
MOCK_OLLAMA_DELAY_MS=800
MOCK_TTS_DELAY_MS=300

# STT - faster-whisper
STT_MODEL=tiny
STT_MIN_AUDIO_BYTES=8000
STT_MAX_AUDIO_SECONDS=8
STT_COMPUTE_TYPE=auto

# SAM - FastSAM
SAM_MODEL=FastSAM-s.pt
SAM_MAX_CROPS=2
SAM_MIN_AREA_FRACTION=0.02

# Caption model - HuggingFace Transformers
BLIP_MODEL=Salesforce/blip-image-captioning-large
BLIP_MODEL_REVISION=
BLIP_MAX_CAPTIONS=2
BLIP_MAX_NEW_TOKENS=24

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_NUM_CTX=512
OLLAMA_NUM_PREDICT=64
OLLAMA_TEMPERATURE=0.1
OLLAMA_KEEP_ALIVE=30m
SCENE_OLLAMA_MODEL=qwen2.5:7b
SCENE_OLLAMA_NUM_PREDICT=64
SCENE_OLLAMA_NUM_CTX=512
OCR_SUMMARY_MODEL=qwen2.5:7b
OCR_SUMMARY_NUM_PREDICT=72
OCR_SUMMARY_NUM_CTX=512
OCR_BACKEND=paddleocr
OCR_MODEL=glm-ocr:latest
OCR_TIMEOUT_SECONDS=45
PADDLEOCR_LANG=tr
PADDLEOCR_VERSION=PP-OCRv5

# Image / WebSocket limits
MAX_FRAME_SIZE=640
MAX_WS_FRAME_BYTES=10485760

# TTS - Edge TTS
TTS_VOICE=tr-TR-EmelNeural
TTS_RATE=+30%
TTS_STREAMING=true
