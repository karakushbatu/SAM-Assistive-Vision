# ============================================================
# SAM Assistive Vision — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/Mac)
# ============================================================

# Server
APP_NAME="SAM Assistive Vision API"
APP_VERSION="0.1.0"
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ============================================================
# Per-service mock flags
# true  = use mock (no model needed, instant)
# false = use real implementation
# Flip them one by one as you complete each phase.
# ============================================================
MOCK_SAM=true         # Phase 2: set false when FastSAM integrated
MOCK_CLASSIFIER=true  # Phase 3: set false when CLIP integrated
MOCK_TTS=false        # Phase 4A: READY — Edge TTS works, set false now
MOCK_OLLAMA=false     # Phase 4B: set false after Ollama is running locally

# Mock timing (ms) — only active when the corresponding MOCK_* flag is true
MOCK_SAM_DELAY_MS=120
MOCK_CLASSIFIER_DELAY_MS=45
MOCK_OLLAMA_DELAY_MS=800
MOCK_TTS_DELAY_MS=300

# ============================================================
# Ollama (active when MOCK_OLLAMA=false)
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
OLLAMA_TIMEOUT_SECONDS=30

# ============================================================
# TTS — Edge TTS (active when MOCK_TTS=false)
# Turkish voices: tr-TR-EmelNeural (female) / tr-TR-AhmetNeural (male)
# Speed: +0% normal, +20% faster, -10% slower
# ============================================================
TTS_VOICE=tr-TR-EmelNeural
TTS_RATE=+0%
